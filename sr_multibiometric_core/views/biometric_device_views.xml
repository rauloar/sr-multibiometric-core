<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Form View ──────────────────────────────────────────────────────── -->
    <record id="view_biometric_device_form" model="ir.ui.view">
        <field name="name">biometric.device.form</field>
        <field name="model">biometric.device</field>
        <field name="arch" type="xml">
            <form string="Biometric Device">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="online,offline,error"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <label for="name" string="Device Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Main Entrance Terminal"/>
                        </h1>
                    </div>

                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="driver_installed or not driver_id">
                        <strong>Driver not installed.</strong>
                        The <field name="driver_id" readonly="1" nolabel="1"/> driver module
                        is not installed on this system.
                        <button name="action_install_driver"
                                string="Install Driver"
                                type="object"
                                class="btn-warning btn-sm ms-2"/>
                    </div>

                    <group>
                        <group string="Connection">
                            <field name="driver_id"/>
                            <field name="ip"/>
                            <field name="sdk_mode"/>
                            <field name="port"/>
                            <field name="username"/>
                            <field name="password" password="True"/>
                        </group>
                        <group string="Location &amp; Time">
                            <field name="location"/>
                            <field name="timezone"/>
                            <field name="last_sync"/>
                        </group>
                    </group>

                    <group string="Synchronization">
                        <field name="auto_sync"/>
                        <field name="sync_interval"
                               invisible="not auto_sync"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List View ─────────────────────────────────────────────────────── -->
    <record id="view_biometric_device_list" model="ir.ui.view">
        <field name="name">biometric.device.list</field>
        <field name="model">biometric.device</field>
        <field name="arch" type="xml">
            <list string="Biometric Devices">
                <field name="name"/>
                <field name="driver_id"/>
                <field name="ip"/>
                <field name="port"/>
                <field name="location"/>
                <field name="auto_sync"/>
                <field name="last_sync"/>
                <field name="status"
                       decoration-success="status == 'online'"
                       decoration-danger="status == 'error'"
                       decoration-muted="status == 'offline'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────────── -->
    <record id="view_biometric_device_search" model="ir.ui.view">
        <field name="name">biometric.device.search</field>
        <field name="model">biometric.device</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ip"/>
                <field name="location"/>
                <field name="driver_id"/>
                <filter name="filter_active" string="Active" domain="[('active','=',True)]"/>
                <filter name="filter_archived" string="Archived" domain="[('active','=',False)]"/>
                <filter name="filter_auto_sync" string="Auto-Sync On" domain="[('auto_sync','=',True)]"/>
                <filter name="filter_online" string="Online" domain="[('status','=','online')]"/>
                <filter name="filter_error" string="Error" domain="[('status','=','error')]"/>
                <separator/>
                <group>
                    <filter name="group_location" string="Location" context="{'group_by': 'location'}"/>
                    <filter name="group_type" string="Brand" context="{'group_by': 'driver_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Window Action ─────────────────────────────────────────────────── -->
    <record id="action_biometric_device" model="ir.actions.act_window">
        <field name="name">Biometric Devices</field>
        <field name="res_model">biometric.device</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_biometric_device_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first biometric terminal
            </p>
            <p>
                Register biometric devices to start synchronizing attendance logs automatically.
            </p>
        </field>
    </record>

    <!-- ── Menu Item ─────────────────────────────────────────────────────── -->
    <menuitem id="menu_biometric_device"
              name="Biometric Devices"
              parent="menu_biometric_devices"
              action="action_biometric_device"
              sequence="50"
              groups="hr_attendance.group_hr_attendance_manager"/>

</odoo>
